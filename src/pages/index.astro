---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import site from '../data/site.json';

const iconMap = {
  leads: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>`,
  office: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  cowork: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>`,
  codeviewr: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
};
---

<Base title="CreateSuite | O Ecossistema Definitivo de Aplicações Web">
  <Nav />

  <!-- Hero -->
  <section id="laboratorio" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-primary/10 rounded-full blur-[120px] -z-10"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-secondary/10 rounded-full blur-[100px] -z-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <div class="text-center lg:text-left z-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm text-slate-300 mb-6">
            <span class="flex h-2 w-2 rounded-full bg-primary"></span>
            {site.hero.badge}
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-[1.1]">
            {site.hero.headline} <span class="gradient-text">{site.hero.headlineHighlight}</span>
          </h1>
          <p class="text-lg text-slate-400 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">{site.hero.description}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href={site.hero.ctaPrimary.url} target="_blank" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold rounded-full text-slate-900 bg-gradient-to-r from-primary to-secondary hover:shadow-lg hover:shadow-primary/30 hover:-translate-y-1 transition-all duration-200">
              {site.hero.ctaPrimary.text}
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href={site.hero.ctaSecondary.url} class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-full text-slate-300 glass-panel hover:bg-white/10 hover:text-white transition-all duration-200">
              {site.hero.ctaSecondary.text}
            </a>
          </div>
          <div class="mt-10 flex items-center justify-center lg:justify-start gap-4 text-sm text-slate-500">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-slate-700 border-2 border-dark"></div>
              <div class="w-8 h-8 rounded-full bg-slate-600 border-2 border-dark"></div>
              <div class="w-8 h-8 rounded-full bg-slate-500 border-2 border-dark"></div>
            </div>
            <p>Junte-se à comunidade de inovadores</p>
          </div>
        </div>

        <!-- App Showcase Window -->
        <div class="relative mx-auto w-full max-w-lg lg:max-w-none z-10 mt-12 lg:mt-0">
          <div class="relative rounded-2xl bg-surface border border-white/10 shadow-2xl shadow-primary/10 overflow-hidden aspect-[4/3] transform transition-transform duration-500 lg:-rotate-2 hover:rotate-0">
            <div class="flex items-center px-4 py-3 bg-white/5 border-b border-white/5">
              <div class="flex space-x-2">
                <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              </div>
              <div class="mx-auto px-4 py-1 rounded-md bg-dark/50 border border-white/5 text-xs text-slate-400 font-mono w-1/2 text-center" id="browser-url">toolbox.createsuite.app</div>
            </div>
            <div class="relative w-full h-[calc(100%-48px)] bg-dark overflow-hidden" id="app-slider">
              <div class="absolute inset-0 p-6 flex flex-col slide-enter z-20" id="slide-0">
                <div class="flex items-center gap-2 mb-6"><div class="w-8 h-8 rounded bg-primary/20 flex items-center justify-center text-primary"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg></div><span class="font-bold text-white">CS Toolbox</span></div>
                <div class="grid grid-cols-2 gap-4 h-full">
                  <div class="bg-white/5 rounded-lg border border-white/5 p-4 flex flex-col justify-center items-center gap-2"><div class="w-10 h-10 rounded-full bg-primary/20 mb-2"></div><div class="h-2 w-16 bg-white/10 rounded"></div><div class="h-2 w-24 bg-white/5 rounded"></div></div>
                  <div class="bg-white/5 rounded-lg border border-white/5 p-4 flex flex-col justify-center items-center gap-2"><div class="w-10 h-10 rounded-full bg-emerald-500/20 mb-2"></div><div class="h-2 w-16 bg-white/10 rounded"></div><div class="h-2 w-24 bg-white/5 rounded"></div></div>
                  <div class="bg-white/5 rounded-lg border border-white/5 p-4 flex flex-col justify-center items-center gap-2"><div class="w-10 h-10 rounded-full bg-teal-500/20 mb-2"></div><div class="h-2 w-16 bg-white/10 rounded"></div><div class="h-2 w-24 bg-white/5 rounded"></div></div>
                  <div class="bg-white/5 rounded-lg border border-white/5 p-4 flex flex-col justify-center items-center gap-2"><div class="w-10 h-10 rounded-full bg-cyan-500/20 mb-2"></div><div class="h-2 w-16 bg-white/10 rounded"></div><div class="h-2 w-24 bg-white/5 rounded"></div></div>
                </div>
              </div>
              <div class="absolute inset-0 p-6 flex flex-col slide-leave z-10" id="slide-1">
                <div class="flex items-center gap-2 mb-6"><div class="w-8 h-8 rounded bg-blue-500/20 flex items-center justify-center text-blue-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg></div><span class="font-bold text-white">CS Leads</span></div>
                <div class="flex-1 bg-white/5 border border-white/5 rounded-lg p-4 flex items-end gap-2">
                  <div class="w-1/6 bg-blue-500/40 rounded-t-md h-1/4"></div><div class="w-1/6 bg-blue-500/60 rounded-t-md h-2/4"></div><div class="w-1/6 bg-blue-500/80 rounded-t-md h-1/3"></div><div class="w-1/6 bg-blue-400 rounded-t-md h-3/4"></div><div class="w-1/6 bg-blue-500/90 rounded-t-md h-2/3"></div>
                  <div class="w-1/6 bg-blue-300 rounded-t-md h-full relative"><div class="absolute -top-3 -right-2 w-3 h-3 bg-white rounded-full shadow-[0_0_10px_rgba(255,255,255,0.8)]"></div></div>
                </div>
              </div>
              <div class="absolute inset-0 p-6 flex flex-col slide-leave z-10" id="slide-2">
                <div class="flex items-center gap-2 mb-6"><div class="w-8 h-8 rounded bg-emerald-500/20 flex items-center justify-center text-emerald-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg></div><span class="font-bold text-white">CS Office</span></div>
                <div class="flex-1 flex gap-4">
                  <div class="w-1/3 bg-white/5 border border-white/5 rounded-lg p-3 space-y-3"><div class="h-2 w-1/2 bg-white/20 rounded"></div><div class="h-16 bg-white/10 rounded"></div><div class="h-16 bg-white/10 rounded"></div></div>
                  <div class="w-1/3 bg-white/5 border border-white/5 rounded-lg p-3 space-y-3"><div class="h-2 w-1/2 bg-white/20 rounded"></div><div class="h-24 bg-white/10 rounded"></div></div>
                  <div class="w-1/3 bg-white/5 border border-white/5 rounded-lg p-3 space-y-3"><div class="h-2 w-1/2 bg-white/20 rounded"></div><div class="h-16 bg-white/10 rounded border border-emerald-500/50 relative"><div class="absolute right-2 top-2 w-2 h-2 rounded-full bg-emerald-400"></div></div></div>
                </div>
              </div>
              <div class="absolute inset-0 p-6 flex flex-col slide-leave z-10" id="slide-3">
                <div class="flex items-center gap-2 mb-4"><div class="w-8 h-8 rounded bg-sky-500/20 flex items-center justify-center text-sky-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg></div><span class="font-bold text-white">CS Cowork</span></div>
                <div class="flex-1 flex gap-4">
                  <div class="w-2/3 bg-white/5 border border-white/5 rounded-lg relative overflow-hidden flex items-center justify-center"><div class="absolute inset-0 bg-gradient-to-br from-sky-900/40 to-dark/80"></div><div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-sm z-10"><div class="w-8 h-8 rounded-full bg-sky-500/50"></div></div></div>
                  <div class="w-1/3 flex flex-col gap-2">
                    <div class="flex-1 bg-white/5 border border-white/5 rounded-lg p-2"><div class="flex items-center gap-2 mb-2"><div class="w-4 h-4 rounded-full bg-white/20"></div><div class="h-1.5 w-12 bg-white/20 rounded"></div></div><div class="h-1.5 w-full bg-white/10 rounded mb-1"></div><div class="h-1.5 w-3/4 bg-white/10 rounded"></div></div>
                    <div class="flex-1 bg-white/5 border border-white/5 rounded-lg p-2"><div class="flex items-center gap-2 mb-2"><div class="w-4 h-4 rounded-full bg-sky-400/50"></div><div class="h-1.5 w-12 bg-sky-400/50 rounded"></div></div><div class="h-1.5 w-full bg-sky-400/20 rounded mb-1"></div><div class="h-1.5 w-2/3 bg-sky-400/20 rounded"></div></div>
                  </div>
                </div>
              </div>
              <div class="absolute inset-0 p-6 flex flex-col slide-leave z-10" id="slide-4">
                <div class="flex items-center gap-2 mb-4"><div class="w-8 h-8 rounded bg-fuchsia-500/20 flex items-center justify-center text-fuchsia-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg></div><span class="font-bold text-white">CodeViewr</span></div>
                <div class="flex-1 flex gap-4">
                  <div class="w-1/2 bg-black/50 border border-white/5 rounded-lg p-3 font-mono text-[10px] leading-relaxed flex flex-col gap-1 text-slate-300">
                    <div class="text-pink-400">&lt;div <span class="text-green-300">class</span>="<span class="text-yellow-300">editor</span>"&gt;</div>
                    <div class="pl-3 text-blue-400">&lt;h1&gt;<span class="text-white">CodeViewr</span>&lt;/h1&gt;</div>
                    <div class="pl-3 text-slate-500">&lt;!-- Code --&gt;</div>
                    <div class="text-pink-400">&lt;/div&gt;</div>
                  </div>
                  <div class="w-1/2 bg-white/5 border border-white/5 rounded-lg flex items-center justify-center relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-tr from-fuchsia-900/30 to-dark/80"></div><div class="w-16 h-12 border border-white/20 rounded bg-dark/80 backdrop-blur flex items-center justify-center z-10 shadow-xl"><div class="w-8 h-2 bg-fuchsia-500/50 rounded"></div></div></div>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 flex space-x-2 bg-dark/80 backdrop-blur-md px-4 py-2 rounded-full border border-white/10">
            <button class="w-2 h-2 rounded-full bg-white transition-all duration-300 indicator-btn" data-target="0"></button>
            <button class="w-2 h-2 rounded-full bg-white/30 transition-all duration-300 indicator-btn" data-target="1"></button>
            <button class="w-2 h-2 rounded-full bg-white/30 transition-all duration-300 indicator-btn" data-target="2"></button>
            <button class="w-2 h-2 rounded-full bg-white/30 transition-all duration-300 indicator-btn" data-target="3"></button>
            <button class="w-2 h-2 rounded-full bg-white/30 transition-all duration-300 indicator-btn" data-target="4"></button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CS Toolbox Section -->
  <section id="toolbox" class="py-24 relative bg-surface/50 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="absolute inset-0 bg-primary/10 blur-[100px] rounded-full"></div>
          <div class="relative glass-panel rounded-2xl p-8 border border-white/10">
            <div class="flex items-center gap-4 mb-8 pb-8 border-b border-white/10">
              <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg shadow-primary/20">
                <svg class="w-8 h-8 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-white">CS Toolbox</h3>
                <p class="text-slate-400">O cinto de utilidades definitivo</p>
              </div>
            </div>
            <div class="space-y-6">
              {site.toolbox.features.map((feature) => (
                <div class="flex gap-4">
                  <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-white">{feature.title}</h4>
                    <p class="text-sm text-slate-400 mt-1">{feature.description}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-8 pt-8 border-t border-white/10">
              <a href={site.toolbox.ctaUrl} target="_blank" class="w-full flex items-center justify-center px-6 py-3 text-base font-medium rounded-lg text-dark bg-white hover:bg-slate-100 transition-colors">{site.toolbox.ctaText}</a>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">{site.toolbox.sectionTitle} <span class="gradient-text">{site.toolbox.sectionTitleHighlight}</span> {site.toolbox.sectionTitle2}</h2>
          <p class="text-lg text-slate-400 mb-8 leading-relaxed" set:html={site.toolbox.description.replace('CS Toolbox', '<strong>CS Toolbox</strong>')} />
          <div class="grid grid-cols-2 gap-6 mt-12">
            {site.toolbox.stats.map((stat) => (
              <div class="border-l-2 border-primary pl-4">
                <div class="text-4xl font-extrabold text-white mb-1">{stat.value}</div>
                <div class="text-sm text-slate-400 font-medium uppercase tracking-wider">{stat.label}</div>
              </div>
            ))}
          </div>
          <div class="mt-12 inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full border-2 border-dark bg-primary/30 flex items-center justify-center text-xs font-bold text-slate-900">D</div>
              <div class="w-8 h-8 rounded-full border-2 border-dark bg-secondary/30 flex items-center justify-center text-xs font-bold text-white">A</div>
              <div class="w-8 h-8 rounded-full border-2 border-dark bg-emerald-700/50 flex items-center justify-center text-xs font-bold text-white">M</div>
            </div>
            <span class="text-sm text-slate-300">"{site.toolbox.testimonial}"</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Apps Ecosystem -->
  <section id="ecossistema" class="py-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{site.ecosystem.sectionTitle} <span class="gradient-text">{site.ecosystem.sectionTitleHighlight}</span></h2>
        <p class="text-lg text-slate-400">{site.ecosystem.description}</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {site.apps.map((app) => (
          <a href={app.url} target="_blank" class={`group relative bg-surface border border-white/5 rounded-2xl p-6 hover:border-${app.color}-500/50 transition-all duration-300 hover:-translate-y-1 block overflow-hidden`}>
            <div class={`absolute top-0 right-0 w-32 h-32 bg-${app.color}-500/10 rounded-bl-full -z-10 transition-transform group-hover:scale-110`}></div>
            <div class={`w-14 h-14 rounded-xl bg-${app.color}-500/10 flex items-center justify-center mb-6 text-${app.color}-400 group-hover:bg-${app.color}-500 group-hover:text-white transition-colors`}>
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[app.id]} />
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{app.name}</h3>
            <p class="text-slate-400 text-sm mb-4">{app.description}</p>
            <div class={`flex items-center text-${app.color}-400 text-sm font-medium`}>
              Acessar Aplicação
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
  <CookieBanner />
</Base>

<script>
  const urls = ['toolbox.createsuite.app','leads.createsuite.app','office.createsuite.app','cowork.createsuite.app','codeviewr.app'];
  const urlDisplay = document.getElementById('browser-url');
  let currentSlide = 0;
  const indicators = document.querySelectorAll('.indicator-btn');

  function goToSlide(index) {
    document.getElementById('slide-' + currentSlide).classList.replace('slide-enter','slide-leave');
    document.getElementById('slide-' + currentSlide).classList.replace('z-20','z-10');
    indicators[currentSlide].classList.replace('bg-white','bg-white/30');
    currentSlide = index;
    document.getElementById('slide-' + currentSlide).classList.replace('slide-leave','slide-enter');
    document.getElementById('slide-' + currentSlide).classList.replace('z-10','z-20');
    indicators[currentSlide].classList.replace('bg-white/30','bg-white');
    urlDisplay.style.opacity = '0';
    setTimeout(() => { urlDisplay.textContent = urls[currentSlide]; urlDisplay.style.opacity = '1'; }, 300);
  }

  let interval = setInterval(() => goToSlide((currentSlide + 1) % 5), 4000);
  indicators.forEach(btn => btn.addEventListener('click', (e) => {
    clearInterval(interval);
    const t = parseInt(e.target.getAttribute('data-target'));
    if (t !== currentSlide) goToSlide(t);
    interval = setInterval(() => goToSlide((currentSlide + 1) % 5), 4000);
  }));
</script>
