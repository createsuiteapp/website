<!-- Cookie Banner -->
<div id="cookie-banner" class="fixed bottom-0 left-0 w-full z-50 transform translate-y-full transition-transform duration-500 ease-in-out bg-surface/95 backdrop-blur-md border-t border-white/10 p-4 sm:p-6 hidden">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
    <div class="text-sm text-slate-300 flex-1">
      Utilizamos cookies para melhorar a sua experiência, analisar o tráfego e personalizar conteúdo. Ao continuar a navegar, concorda com a nossa
      <a href="/privacidade" class="text-primary hover:text-primaryHover underline transition-colors">Política de Privacidade</a>.
    </div>
    <div class="flex flex-col sm:flex-row items-center gap-3 shrink-0 w-full sm:w-auto">
      <button id="btn-customize-cookies" class="w-full sm:w-auto px-5 py-2.5 text-sm font-medium rounded-lg text-slate-300 bg-white/5 hover:bg-white/10 border border-white/10 transition-colors">Personalizar</button>
      <button id="btn-accept-all-cookies" class="w-full sm:w-auto px-5 py-2.5 text-sm font-bold rounded-lg text-slate-900 bg-primary hover:bg-primaryHover transition-colors shadow-lg shadow-primary/20">Aceitar Todos</button>
    </div>
  </div>
</div>

<!-- Cookie Modal -->
<div id="cookie-modal" class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-dark/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 hidden">
  <div class="bg-surface border border-white/10 rounded-2xl w-full max-w-lg shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]" id="cookie-modal-content">
    <div class="p-6 border-b border-white/10 flex justify-between items-center shrink-0">
      <h3 class="text-xl font-bold text-white">Preferências de Cookies</h3>
      <button id="btn-close-modal" class="text-slate-400 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="p-6 space-y-6 overflow-y-auto">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h4 class="text-white font-medium mb-1">Estritamente Necessários</h4>
          <p class="text-sm text-slate-400 leading-relaxed">Essenciais para o funcionamento do site. Não podem ser desativados.</p>
        </div>
        <label class="relative inline-flex items-center cursor-not-allowed shrink-0 mt-1">
          <input type="checkbox" checked disabled class="sr-only peer">
          <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary/50 opacity-70"></div>
        </label>
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <h4 class="text-white font-medium mb-1">Desempenho e Analíticos</h4>
          <p class="text-sm text-slate-400 leading-relaxed">Permitem contar visitas e fontes de tráfego para medir e melhorar o desempenho.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0 mt-1">
          <input type="checkbox" id="toggle-analytics" class="sr-only peer" checked>
          <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
        </label>
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <h4 class="text-white font-medium mb-1">Marketing e Publicidade</h4>
          <p class="text-sm text-slate-400 leading-relaxed">Usados para acompanhar os visitantes e exibir anúncios relevantes.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0 mt-1">
          <input type="checkbox" id="toggle-marketing" class="sr-only peer">
          <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
        </label>
      </div>
    </div>
    <div class="p-6 border-t border-white/10 flex justify-end bg-white/5 rounded-b-2xl shrink-0">
      <button id="btn-save-preferences" class="px-6 py-2.5 text-sm font-bold rounded-lg text-slate-900 bg-primary hover:bg-primaryHover transition-colors">Guardar Preferências</button>
    </div>
  </div>
</div>

<script>
  const COOKIE_NAME = 'cs_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  const modal = document.getElementById('cookie-modal');
  const modalContent = document.getElementById('cookie-modal-content');

  function hideBanner() {
    banner.classList.add('translate-y-full');
    setTimeout(() => banner.classList.add('hidden'), 500);
  }
  function openModal() {
    modal.classList.remove('hidden');
    setTimeout(() => { modal.classList.remove('opacity-0', 'pointer-events-none'); modalContent.classList.remove('scale-95'); }, 10);
    const c = JSON.parse(localStorage.getItem(COOKIE_NAME) || '{}');
    document.getElementById('toggle-analytics').checked = c.analytics !== false;
    document.getElementById('toggle-marketing').checked = c.marketing === true;
  }
  function closeModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modalContent.classList.add('scale-95');
    setTimeout(() => modal.classList.add('hidden'), 300);
  }
  function saveConsent(prefs) {
    localStorage.setItem(COOKIE_NAME, JSON.stringify(prefs));
    hideBanner(); closeModal();
  }

  if (!localStorage.getItem(COOKIE_NAME)) {
    banner.classList.remove('hidden');
    setTimeout(() => banner.classList.remove('translate-y-full'), 50);
  }

  document.getElementById('btn-accept-all-cookies').addEventListener('click', () => saveConsent({ necessary: true, analytics: true, marketing: true }));
  document.getElementById('btn-customize-cookies').addEventListener('click', openModal);
  document.getElementById('btn-close-modal').addEventListener('click', closeModal);
  document.getElementById('btn-save-preferences').addEventListener('click', () => {
    saveConsent({ necessary: true, analytics: document.getElementById('toggle-analytics').checked, marketing: document.getElementById('toggle-marketing').checked });
  });
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
</script>
