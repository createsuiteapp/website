---
export interface Props {
  showToolboxButton?: boolean;
}
const { showToolboxButton = true } = Astro.props;
---
<nav class="fixed w-full z-50 glass-panel border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center gap-3 cursor-pointer hover:opacity-80 transition-opacity">
        <img src="/cs-logo.svg" alt="CreateSuite" class="h-8 w-auto" />
      </a>
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href="/#laboratorio" class="text-slate-300 hover:text-white transition-colors px-3 py-2 rounded-md text-sm font-medium">Laboratório</a>
          <a href="/#toolbox" class="text-slate-300 hover:text-white transition-colors px-3 py-2 rounded-md text-sm font-medium">CS Toolbox</a>
          <a href="/#ecossistema" class="text-slate-300 hover:text-white transition-colors px-3 py-2 rounded-md text-sm font-medium">Aplicações</a>
        </div>
      </div>
      {showToolboxButton && (
        <div>
          <a href="https://toolbox.createsuite.app" target="_blank" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-medium rounded-full text-white bg-white/10 hover:bg-white/20 hover:scale-105 transition-all duration-200">
            Acessar Ferramentas
          </a>
        </div>
      )}
    </div>
  </div>
</nav>
